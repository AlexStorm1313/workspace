            "0.0.0.0/0",
            "::/0"
        ],
        "auth": {
            "mode": "none"
        },
        "controlUi": {
            "allowInsecureAuth": true,
            "enabled": true,
            "dangerouslyDisableDeviceAuth": true,
            "allowedOrigins": [
                "http://localhost:18789",
                "http://127.0.0.1:18789",
                "https://openclaw.workspace.localhost:8443",
                "https://codex.openclaw.workspace.localhost:8443",
                "http://openclaw.workspace.localhost:18789",
                "http://codex.openclaw.workspace.localhost:18789"
            ]
        }
    },
    "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://workspace-ollama-pod:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "gemma4:latest",
            "name": "Gemma 4",
            "reasoning": false,
            "input": ["text"]
          }
