{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.6-luna",
  "enabled_providers": [
    "openai"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://workspace-chromium-pod:9223",
        "--no-usage-statistics"
      ]
    }
  }
}
